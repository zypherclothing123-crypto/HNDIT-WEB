# Copy to `.env.local` and fill with your Supabase project + Gemini values.

# --- App URL (Auth: add to Supabase → Authentication → URL Configuration) ---
# Site URL + Redirect URLs should include e.g. http://localhost:3000/auth/callback
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Never commit `.env.local` (it is gitignored).

# --- Supabase (Settings → API) ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://zimdhbndocruihgmxhsy.supabase.co

# Project → anon (public) key — safe for browser with RLS enabled
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InppbWRoYm5kb2NydWloZ214aHN5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ1MDkxMTgsImV4cCI6MjEwMDA4NTExOH0.2eaaUeC2hwqYuIpo2GJMfgb1Hj9ZLSX_Eh86v8q1cO0

# --- Gemini (Google AI Studio) — server/client features use this in lib/gemini.ts ---
NEXT_PUBLIC_GEMINI_API_KEY=

# Optional model override (default in code: gemini-2.5-flash)
# NEXT_PUBLIC_GEMINI_MODEL=

# Optional comma-separated fallback models
# NEXT_PUBLIC_GEMINI_MODEL_FALLBACKS=
